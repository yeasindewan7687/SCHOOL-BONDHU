rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Collection: chat_sessions ---
    // Anyone can create a session (for general chatbot use)
    // Only the 'session' owner (theoretical, based on ID possession) can update.
    // In this app, we don't have session-auth binding, so we rely on session ID.
    match /chat_sessions/{sessionId} {
      function isValidChatSession(data) {
        return data.keys().hasAll(['messages', 'createdAt', 'updatedAt'])
               && data.keys().size() == 3
               && data.messages is list
               && data.messages.size() <= 100 // Limit history per session
               && data.createdAt is timestamp
               && data.updatedAt is timestamp;
      }

      allow get: if true;
      allow create: if isValidChatSession(incoming())
                       && incoming().createdAt == request.time
                       && incoming().updatedAt == request.time;
      
      allow update: if isValidChatSession(incoming())
                       && incoming().updatedAt == request.time
                       && incoming().createdAt == existing().createdAt
                       && (
                         incoming().diff(existing()).affectedKeys().hasOnly(['messages', 'updatedAt'])
                       );
      
      allow delete: if isAdmin();
      allow list: if isAdmin();
    }

    // --- Collection: chatbot_settings ---
    match /chatbot_settings/config {
      function isValidChatbotConfig(data) {
        return data.keys().hasAll(['prompt', 'updatedAt'])
               && data.keys().size() == 2
               && data.prompt is string
               && data.prompt.size() <= 5000
               && data.updatedAt is timestamp;
      }

      allow get: if true;
      allow write: if isAdmin() && isValidChatbotConfig(incoming()) && incoming().updatedAt == request.time;
    }

    // --- Collection: admins ---
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed via Firebase Console or special script
    }
  }
}
